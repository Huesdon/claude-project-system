{
  "cps_dir": ".cps",
  "project_root": "",
  "source_paths": [
    "Documentation/md/**/*.md",
    "Reference/**/*.md",
    "SNP-*/*/flags.json",
    "SNP-*/*/scope_flags.json",
    "SNP-*/*/handoffs.json",
    "SNP-*/*/exceptions.json",
    "SNP-*/*/availability.json",
    "SNP-*/*/sprint_progress.json"
  ],
  "embedding_model": "all-MiniLM-L6-v2",
  "embedding_dim": 384,
  "chunk_min_tokens": 50,
  "chunk_max_tokens": 2000,
  "search_default_limit": 5,
  "auto_refresh_on_startup": true,
  "cache": {
    "similarity_threshold": 0.05,
    "max_age_hours": 24
  }
}
